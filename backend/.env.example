# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Anthropic API Key — get it from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server config
PORT=4000
NODE_ENV=development

# Razorpay — get keys from https://dashboard.razorpay.com/app/keys
# Use test keys during development (rzp_test_...)
# Switch to live keys (rzp_live_...) before going live
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# CORS — set this to your frontend URL in production
# e.g. https://resumeiq.in
ALLOWED_ORIGIN=http://localhost:3456

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=30
